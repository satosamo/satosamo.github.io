---
layout: layouts/base.njk
---
{% if node.isRoot %}
  <section class="hero">
    <p class="eyebrow">Personal knowledge repository</p>
    <h1 class="hero-title">{{ site.title }}</h1>
    <p class="hero-sub">{{ site.subtitle }}</p>
  </section>
{% else %}
  <nav class="crumbs" aria-label="Breadcrumb">
    {% for c in node.breadcrumbs %}<a href="{{ c.url }}">{{ c.title }}</a><span class="crumb-sep" aria-hidden="true">/</span>{% endfor %}<span aria-current="page">{{ node.title }}</span>
  </nav>
  <section class="section-head">
    <h1>{{ node.title }}</h1>
    <p class="section-meta">{{ node.count }} page{% if node.count != 1 %}s{% endif %}{% if node.blurb %} · {{ node.blurb }}{% endif %}</p>
  </section>
{% endif %}

{% if node.items.length %}
<div class="lattice">
  {% for item in node.items %}
    {% if item.kind == "break" %}
    <div class="lattice-break"></div>
    {%- else -%}
      <a class="tile" href="{{ item.url }}">
        <span class="tile-eyebrow">
          {%- if item.draft -%}Draft · {% endif -%}
          {%- if item.kind == "section" -%}
            Section · {{ item.count }} page{% if item.count != 1 %}s{% endif %}
          {%- elif item.kind == "course" -%}
            Course
          {%- else -%}
            Article
          {%- endif -%}
        </span>
        <span class="tile-title">{{ item.title }}</span>
        {% if item.summary %}<span class="tile-summary">{{ item.summary }}</span>{% endif %}
        {% if item.glyph %}
        <span class="tile-glyph" aria-hidden="true">
          {%- include "glyphs/" + item.glyph + ".svg" ignore missing -%}
        </span>
        {% endif %}
      </a>
    {% endif %}
  {% endfor %}
</div>
{% else %}
<p class="empty">Nothing here yet — add a markdown file under <code>src/content/{{ node.path }}</code> to begin.</p>
{% endif %}
